#!/usr/bin/env bash
# asdf list-all: fetch all versions from GitHub Releases
set -euo pipefail

repo="${SAFESELECT_REPO:-antonillos/safeselect}"

git ls-remote --tags --refs "https://github.com/${repo}.git" \
  | sed -nE 's#.*refs/tags/v?([0-9]+\.[0-9]+\.[0-9]+(-[A-Za-z0-9.]+)?)$#\1#p' \
  | sort -V
